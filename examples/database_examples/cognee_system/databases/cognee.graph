{"directed": true, "multigraph": true, "graph": {}, "nodes": [{"created_at": 1752177700707, "updated_at": 1752177700707, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["text"]}, "type": "DocumentChunk", "belongs_to_set": null, "text": "PGVector is an extension for PostgreSQL that adds vector similarity search capabilities.\n    It supports multiple indexing methods, including IVFFlat, HNSW, and brute-force search.\n    PGVector allows you to store vector embeddings directly in your PostgreSQL database.\n    It provides distance functions like L2 distance, inner product, and cosine distance.\n    Using PGVector, you can perform both metadata filtering and vector similarity search in a single query.\n    The extension is often used for applications like semantic search, recommendations, and image similarity.", "chunk_size": 209, "chunk_index": 0, "cut_type": "sentence_end", "id": "84ef86b6-a426-5b22-8ed1-5434d0e52b2f"}, {"created_at": 1752177716240, "updated_at": 1752177716240, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "Entity", "belongs_to_set": null, "name": "semantic search", "description": "A search method that focuses on the intent behind the search.", "id": "9d6360d4-504a-5f7f-b618-c2ea457a1a4d"}, {"created_at": 1752177716240, "updated_at": 1752177716240, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "EntityType", "belongs_to_set": null, "name": "application", "description": "application", "id": "701bfdd2-b7ba-5eb9-84b8-2ce8f51127a1"}, {"created_at": 1752177716235, "updated_at": 1752177716235, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "Entity", "belongs_to_set": null, "name": "pgvector", "description": "An extension for PostgreSQL that adds vector similarity search capabilities.", "id": "ba26f56f-aebc-5570-bc57-9abb9029b29f"}, {"created_at": 1752177716234, "updated_at": 1752177716234, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "EntityType", "belongs_to_set": null, "name": "extension", "description": "extension", "id": "be664a56-b572-5100-b475-739b41507e29"}, {"created_at": 1752177716238, "updated_at": 1752177716238, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "Entity", "belongs_to_set": null, "name": "vector embeddings", "description": "Numerical representations of data in vector form.", "id": "50ebed4c-8fd8-52cd-9111-3b5e211a1a10"}, {"created_at": 1752177716238, "updated_at": 1752177716238, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "EntityType", "belongs_to_set": null, "name": "data structure", "description": "data structure", "id": "44018d96-c951-5329-92b2-81c7cc757e52"}, {"created_at": 1752177700256, "updated_at": 1752177700256, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "TextDocument", "belongs_to_set": null, "name": "text_adab87ccb565e44317f81a52f3c60cd8", "raw_data_location": "/Users/andy.kwok/git/neptune/cognee/examples/database_examples/data_storage/data/text_adab87ccb565e44317f81a52f3c60cd8.txt", "external_metadata": "{}", "mime_type": "text/plain", "id": "c43c490d-6693-5d20-8d54-a0b3ac974e17"}, {"created_at": 1752177716241, "updated_at": 1752177716241, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "Entity", "belongs_to_set": null, "name": "image similarity", "description": "A technique used to find similar images based on vector representation.", "id": "6b36ec15-7895-5e69-a2f1-43011a56355d"}, {"created_at": 1752177716236, "updated_at": 1752177716236, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "Entity", "belongs_to_set": null, "name": "postgresql", "description": "An open-source relational database management system.", "id": "a5a23770-1f35-582f-a210-5c4ed2ee2cbd"}, {"created_at": 1752177716235, "updated_at": 1752177716235, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "EntityType", "belongs_to_set": null, "name": "database", "description": "database", "id": "90cb1fed-d3a3-51c4-bf2d-467bce3d40a3"}, {"created_at": 1752177716238, "updated_at": 1752177716238, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "Entity", "belongs_to_set": null, "name": "brute force", "description": "A method to search for vector similarity by checking all vectors.", "id": "0cccb439-c064-5959-8bd6-7cf25b3449bb"}, {"created_at": 1752177716237, "updated_at": 1752177716237, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "EntityType", "belongs_to_set": null, "name": "search method", "description": "search method", "id": "2bc568e2-29ac-5d1d-b6b7-ccaad36bd075"}, {"created_at": 1752177716240, "updated_at": 1752177716240, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "Entity", "belongs_to_set": null, "name": "recommendations", "description": "A system that suggests products or content to users.", "id": "0e54da1a-82ef-5d0b-be5c-6851d2d9cbdd"}, {"created_at": 1752177716239, "updated_at": 1752177716239, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fields": ["name"]}, "type": "Entity", "belongs_to_set": null, "name": "distance functions", "description": "Functions that calculate the distance between vectors.", "id": "f6a4df75-c1d5-526b-b513-70b97456ccdb"}, {"created_at": 1752177716239, "updated_at": 1752177716239, "ontology_valid": false, "version": 1, "topological_rank": 0, "metadata": {"index_fi